{
  // Format on save with prettier (per-language overrides ensure no conflicts).
  "editor.formatOnSave": true,
  "editor.defaultFormatter": "esbenp.prettier-vscode",
  "editor.codeActionsOnSave": {
    // Sort-imports plugin handles imports; disable VS Code's organizer.
    "source.organizeImports": "never"
  },

  // Workspace TypeScript / Prettier — use repo's pinned versions, not Code's
  // built-in older ones.
  "js/ts.tsdk.path": "node_modules/typescript/lib",
  "prettier.requireConfig": true,
  "prettier.prettierPath": "./node_modules/prettier",

  "[typescript]": { "editor.defaultFormatter": "esbenp.prettier-vscode" },
  "[typescriptreact]": { "editor.defaultFormatter": "esbenp.prettier-vscode" },
  "[json]": { "editor.defaultFormatter": "esbenp.prettier-vscode" },
  "[jsonc]": { "editor.defaultFormatter": "esbenp.prettier-vscode" },
  "[yaml]": { "editor.defaultFormatter": "esbenp.prettier-vscode" },
  "[markdown]": { "editor.defaultFormatter": "esbenp.prettier-vscode" },

  // Nx perf — exclude generated/cached dirs from search and FS watcher.
  "search.exclude": {
    "**/node_modules": true,
    "**/dist": true,
    "**/coverage": true,
    "**/.nx": true,
    "**/pnpm-lock.yaml": true,
    "**/*.tsbuildinfo": true
  },
  "files.watcherExclude": {
    "**/node_modules/**": true,
    "**/.nx/**": true,
    "**/dist/**": true
  },

  "npm.packageManager": "pnpm",

  // Project-specific word list for cspell. "Add to workspace dictionary"
  // appends here.
  "cSpell.customDictionaries": {
    "project-words": {
      "name": "project-words",
      "path": "${workspaceFolder}/.cspell/project-words.txt",
      "addWords": true,
      "scope": "workspace"
    }
  },

  // Tailwind class detection inside cn()/cva()/cx()/clsx() helpers.
  "tailwindCSS.experimental.classRegex": [
    ["cva\\(([^)]*)\\)", "[\"'`]([^\"'`]*).*?[\"'`]"],
    ["cn\\(([^)]*)\\)", "(?:'|\"|`)([^']*)(?:'|\"|`)"]
  ]
}
