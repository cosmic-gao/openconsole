{
  "name": "@openconsole/chat",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "description": "Web 版 opencode —— Vue3 聊天界面，经极简 SSE 后端桥接 @openconsole/agent 的 Event 流",
  "scripts": {
    "dev": "concurrently -n server,web -c cyan,green \"pnpm dev:server\" \"pnpm dev:web\"",
    "dev:web": "vite",
    "dev:server": "tsx watch server/index.ts",
    "build": "vite build",
    "preview": "vite preview",
    "typecheck": "vue-tsc --noEmit -p tsconfig.json && tsc --noEmit -p tsconfig.node.json"
  },
  "dependencies": {
    "@langchain/openai": "^1.4.7",
    "@openconsole/agent": "workspace:*",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "lucide-vue-next": "^0.469.0",
    "reka-ui": "^2.2.0",
    "tailwind-merge": "^2.6.0",
    "vue": "^3.5.13"
  },
  "devDependencies": {
    "@openconsole/tsconfig": "workspace:*",
    "@tailwindcss/vite": "^4.0.0",
    "@types/node": "^22.10.2",
    "@vitejs/plugin-vue": "^5.2.1",
    "concurrently": "^9.1.2",
    "tailwindcss": "^4.0.0",
    "tsx": "^4.19.2",
    "typescript": "^6.0.3",
    "vite": "^6.0.7",
    "vue-tsc": "^2.2.0"
  }
}
