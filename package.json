{
  "name": "openconsole",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "nx": "nx",
    "graph": "nx graph",
    "test": "nx run-many -t test",
    "test:coverage": "nx run-many -t test:coverage",
    "typecheck": "nx run-many -t typecheck",
    "check": "nx run-many -t check",
    "build": "nx run-many -t build",
    "lint": "nx run-many -t lint",
    "affected": "nx affected",
    "affected:test": "nx affected -t test",
    "affected:typecheck": "nx affected -t typecheck",
    "affected:check": "nx affected -t check",
    "affected:build": "nx affected -t build",
    "format": "nx format:write",
    "format:check": "nx format:check",
    "release": "nx release",
    "release:dry-run": "nx release --dry-run",
    "release:version": "nx release version",
    "release:changelog": "nx release changelog",
    "release:publish": "nx release publish",
    "reset": "nx reset",
    "prepare": "husky"
  },
  "devDependencies": {
    "@commitlint/cli": "^19.6.1",
    "@commitlint/config-conventional": "^19.6.0",
    "@nx/js": "22.7.2",
    "@openconsole/tsconfig": "workspace:*",
    "husky": "^9.1.7",
    "lint-staged": "^15.5.2",
    "nx": "22.7.2",
    "prettier": "^3.4.2",
    "typescript": "^6.0.3",
    "vitest": "^3.2.4"
  },
  "lint-staged": {
    "*": "nx format:write --uncommitted"
  }
