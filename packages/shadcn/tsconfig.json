{
  "$schema": "https://json.schemastore.org/tsconfig",
  "extends": [
    "@openconsole/tsconfig/lib",
    "@openconsole/tsconfig/react"
  ],
  "compilerOptions": {
    "noEmit": true,
    "paths": {
      "@/*": ["./*"]
    }
  },
  "include": ["**/*.ts", "**/*.tsx"],
  "exclude": ["node_modules", "dist"]
}
