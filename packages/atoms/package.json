{
  "name": "@openconsole/atoms",
  "version": "0.2.7",
  "private": false,
  "description": "Next.js 16 业务级组合组件 —— Header / Sidebar / Breadcrumbs / Preferences / Error 页 + 主题、字体、布局 Provider。",
  "keywords": [
    "next.js",
    "nextjs",
    "react",
    "shadcn",
    "ui",
    "components",
    "dashboard",
    "sidebar",
    "theme"
  ],
  "type": "module",
  "sideEffects": [
    "**/*.css"
  ],
  "main": "./index.ts",
  "types": "./index.ts",
  "exports": {
    ".": {
      "types": "./index.ts",
      "default": "./index.ts"
    },
    "./styles.css": "./styles.css"
  },
  "files": [
    "index.ts",
    "styles.css",
    "components",
    "hooks",
    "providers",
    "README.md"
  ],
  "engines": {
    "node": ">=22.11.0"
  },
  "scripts": {
    "typecheck": "tsc --noEmit",
    "check": "tsc --noEmit"
  },
  "peerDependencies": {
    "@openconsole/shadcn": "workspace:*",
    "@tanstack/react-table": "*",
    "cmdk": "*",
    "date-fns": "*",
    "lucide-react": "*",
    "next": "^15 || ^16",
    "next-themes": "*",
    "react": "^19.0.0",
    "react-day-picker": "*",
    "react-dom": "^19.0.0",
    "tailwindcss": "^4.0.0"
  },
  "devDependencies": {
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3"
  }
}
