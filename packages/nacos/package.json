{
  "name": "@openconsole/nacos",
  "version": "0.3.0",
  "private": false,
  "description": "Framework-agnostic Nacos client — service discovery, dynamic config, and a fetch-compatible HTTP layer with plugins. Adapters for Next.js, Hono, and NestJS.",
  "keywords": [
    "nacos",
    "service-discovery",
    "load-balancer",
    "config",
    "microservices",
    "framework-agnostic",
    "nextjs",
    "hono",
    "nestjs",
    "adapter"
  ],
  "type": "module",
  "sideEffects": false,
  "main": "index.ts",
  "types": "index.ts",
  "exports": {
    ".": "./index.ts",
    "./nextjs": "./adapters/nextjs.ts",
    "./hono": "./adapters/hono.ts",
    "./nestjs": "./adapters/nestjs.ts"
  },
  "files": [
    "index.ts",
    "core",
    "adapters",
    "README.md"
  ],
  "engines": {
    "node": ">=22.11.0"
  },
  "scripts": {
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "typecheck": "tsc --noEmit",
    "check": "tsc --noEmit && vitest run"
  },
  "peerDependencies": {
    "nacos": "^2",
    "next": "^16",
    "hono": "^4"
  },
  "peerDependenciesMeta": {
    "next": {
      "optional": true
    },
    "hono": {
      "optional": true
    }
  },
  "dependencies": {
    "server-only": "^0.0.1"
  },
  "devDependencies": {
    "@openconsole/tsconfig": "workspace:*",
    "@types/node": "^25.4.0",
    "hono": "^4.12.21",
    "vitest": "^3.2.4"
  }
}
