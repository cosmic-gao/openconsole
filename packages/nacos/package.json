{
  "name": "@openconsole/nacos",
  "version": "0.1.0",
  "private": false,
  "type": "module",
  "sideEffects": false,
  "exports": {
    ".": "./index.ts",
    "./next": "./adapters/next.ts"
  },
  "scripts": {
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "typecheck": "tsc --noEmit",
    "check": "tsc --noEmit && vitest run"
  },
  "peerDependencies": {
    "nacos": "^2",
    "next": "^15 || ^16"
  },
  "peerDependenciesMeta": {
    "next": { "optional": true }
  },
  "devDependencies": {
    "@openconsole/tsconfig": "workspace:*",
    "@types/node": "^25.4.0"
  },
  "nx": {
    "targets": {
      "nx-release-publish": { "dependsOn": [] }
    }
  }
}
