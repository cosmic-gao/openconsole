{
  "name": "@openconsole/nacos",
  "version": "0.2.1",
  "private": false,
  "description": "Next.js 16 Nacos client — service discovery, dynamic config, and a fetch-compatible HTTP layer with plugins.",
  "keywords": [
    "nacos",
    "next.js",
    "nextjs",
    "service-discovery",
    "load-balancer",
    "config",
    "microservices"
  ],
  "type": "module",
  "sideEffects": false,
  "main": "index.ts",
  "types": "index.ts",
  "exports": {
    ".": {
      "types": "./index.ts",
      "default": "./index.ts"
    }
  },
  "files": [
    "index.ts",
    "core",
    "README.md"
  ],
  "engines": {
    "node": ">=22.11.0"
  },
  "scripts": {
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "typecheck": "tsc --noEmit",
    "check": "tsc --noEmit && vitest run"
  },
  "peerDependencies": {
    "nacos": "^2",
    "next": "^16"
  },
  "devDependencies": {
    "@openconsole/tsconfig": "workspace:*",
    "@types/node": "^25.4.0"
  }
}
