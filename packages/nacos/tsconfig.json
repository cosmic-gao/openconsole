{
  "$schema": "https://json.schemastore.org/tsconfig",
  "extends": [
    "@opendesign/tsconfig/lib",
    "@opendesign/tsconfig/esm"
  ],
  "compilerOptions": {
    "noEmit": true,
    "lib": ["ES2022", "DOM"],
    "types": ["node"]
  },
  "include": [
    "index.ts",
    "core/**/*.ts",
    "adapters/**/*.ts",
    "tests/**/*.ts",
    "vitest.config.ts"
  ],
  "exclude": ["node_modules", "dist"]
}
