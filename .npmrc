# Let pnpm manage the Node runtime — auto-downloads and uses 24.x for every
# `pnpm` invocation. Replaces .nvmrc/nodenv/fnm.
# https://pnpm.io/npmrc#use-node-version
use-node-version=24.16.0

# Refuse to install when engines.{node,pnpm} doesn't match. Prevents
# half-broken installs on machines with the wrong runtime.
engine-strict=true

# Refuse to run when packageManager field disagrees with the active pnpm.
# Pairs with Corepack to lock the pnpm version across the team.
package-manager-strict=true

# pnpm self-installs the version pinned in `packageManager` of package.json
# (Corepack-style) without needing `corepack enable`.
manage-package-manager-versions=true

# CI safety — fail fast if pnpm-lock.yaml drifts. Local dev keeps default.
# Override in CI via `pnpm install --frozen-lockfile`.
prefer-frozen-lockfile=true

# Verify integrity of every package fetched from the store. Default true on
# pnpm 9+, explicit for clarity.
verify-store-integrity=true

# Save exact versions in package.json by default (no ^ / ~). Renovate &
# Dependabot still bump them.
save-exact=false

# Hoist common bin & types only, keep everything else strict (default since
# pnpm 8). Avoids phantom deps.
public-hoist-pattern[]=*types*
public-hoist-pattern[]=*eslint*
public-hoist-pattern[]=*prettier*

# Faster cold installs on CI — store across all repos on the same runner.
store-dir=~/.local/share/pnpm/store
